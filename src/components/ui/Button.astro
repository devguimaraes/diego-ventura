---
import { buttonVariants } from './button';
import { cn } from '@/lib/utils';

export interface Props {
  variant?: 'default' | 'outline' | 'secondary' | 'ghost' | 'destructive' | 'link';
  size?: 'default' | 'xs' | 'sm' | 'lg' | 'icon' | 'icon-xs' | 'icon-sm' | 'icon-lg';
  href?: string;
  class?: string;
}

const { variant = 'default', size = 'default', href, class: extraClass = '' } = Astro.props;
const classes = cn(buttonVariants({ variant, size }), extraClass);
---

{href ? (
  <a href={href} class={classes} data-slot="button">
    <slot />
  </a>
) : (
  <button class={classes} data-slot="button">
    <slot />
  </button>
)}

<script>
  function initMagneticButtons() {
    const magneticButtons = document.querySelectorAll('.btn-magnetic');
    
    magneticButtons.forEach(btn => {
      btn.addEventListener('mousemove', (e) => {
        const mouseEvent = e as MouseEvent;
        const rect = btn.getBoundingClientRect();
        const x = mouseEvent.clientX - rect.left - rect.width / 2;
        const y = mouseEvent.clientY - rect.top - rect.height / 2;
        
        // @ts-ignore
        btn.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
        // @ts-ignore
        btn.style.transition = 'transform 0.1s ease-out';
      });

      btn.addEventListener('mouseleave', () => {
        // @ts-ignore
        btn.style.transform = '';
        // @ts-ignore
        btn.style.transition = 'transform 0.5s cubic-bezier(0.22, 1, 0.36, 1)';
      });
    });
  }

  // Initialize on page load
  initMagneticButtons();
  // Re-initialize after Astro swaps (if using View Transitions)
  document.addEventListener('astro:after-swap', initMagneticButtons);
</script>
