---
import { Input as ShadcnInput } from './input';

export interface Props {
  type?: string;
  name?: string;
  placeholder?: string;
  required?: boolean;
  class?: string;
  [key: string]: any;
}

const { class: extraClass = '', ...props } = Astro.props;
---

<ShadcnInput className={extraClass} {...props} />
