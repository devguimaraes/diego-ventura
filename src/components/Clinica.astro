---
import { clinica, contact } from '../data/site.json';

const addressQuery = encodeURIComponent(
  `${contact.address.street}, ${contact.address.neighborhood}, ${contact.address.city} - ${contact.address.state}`
);
const mapsEmbedUrl = `https://www.google.com/maps?q=${addressQuery}&output=embed`;
---

<section class="py-section-gap px-container-padding-desktop max-w-container-max mx-auto">
  <h2 class="font-manrope text-headline-lg text-on-surface mb-4">{clinica.title}</h2>
  <div class="bg-surface-container p-6 rounded-lg border border-outline-variant/50">
    <p class="font-inter text-body-md text-on-surface-variant/80">
      {contact.address.street}, {contact.address.neighborhood}, {contact.address.city} - {contact.address.state}
    </p>
    <div class="rounded-lg overflow-hidden border border-outline-variant/50 mt-6">
      <iframe
        src={mapsEmbedUrl}
        width="100%"
        height="450"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={clinica.localizacao.title}
      ></iframe>
    </div>
  </div>
</section>
