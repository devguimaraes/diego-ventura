---
import Button from './ui/Button.astro';
import { especialidades } from '../data/site.json';
---

<section id="especialidades" class="py-section-gap px-container-padding-desktop max-w-container-max mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {especialidades.items.map((item) => (
      <article class="p-10 rounded-lg border border-outline-variant/50 bg-surface-container hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(0,0,0,0.3)] hover:border-primary/30 transition-all duration-300">
        <h3 class="font-manrope text-headline-md text-on-surface mb-4">{item.title}</h3>
        <p class="font-inter text-body-md text-on-surface-variant/80 mb-6">{item.description}</p>
        <Button variant="outline" size="default">{item.cta}</Button>
      </article>
    ))}
  </div>
</section>
