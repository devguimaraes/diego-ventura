---
import { depoimentos } from '../data/site.json';
---

<section id="depoimentos" class="py-section-gap px-container-padding-desktop max-w-container-max mx-auto">
  <h2 class="text-headline-lg text-on-surface text-center mb-16">{depoimentos.title}</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    {depoimentos.items.map((item) => (
      <div class="p-8 bg-surface-container rounded-lg border border-outline-variant/50 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(0,0,0,0.3)] transition-all duration-300">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-12 rounded-full bg-primary/20 text-primary flex items-center justify-center font-manrope font-bold text-lg">
            {item.initials}
          </div>
          <div>
            <p class="font-manrope font-semibold text-on-surface">{item.name}</p>
            <p class="font-inter text-sm text-on-surface-variant/60">{item.city}</p>
          </div>
        </div>
        <p class="font-inter text-body-md text-on-surface-variant/80 italic mt-4">
          &ldquo;{item.text}&rdquo;
        </p>
      </div>
    ))}
  </div>
</section>
