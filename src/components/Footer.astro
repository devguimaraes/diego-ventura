---
import { footer, brand } from '../data/site.json';
---

<footer class="py-12 px-16 bg-surface-container-low border-t border-outline-variant/30">
  <div class="max-w-container-max mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="flex flex-col items-center md:items-start gap-4">
      <img src="/images/logo-longa.png" alt={brand.name} class="h-10" />
      <p class="font-inter text-sm text-on-surface-variant/40 max-w-xs text-center md:text-left">
        {footer.description}
      </p>
    </div>
    <nav class="flex flex-wrap justify-center md:justify-end gap-x-8 gap-y-3">
      {footer.links.map((link) => (
        <a
          href={link.href}
          class="font-manrope text-label-md text-on-surface-variant/60 hover:text-primary transition-colors duration-150"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
  <div class="mt-8 pt-6 border-t border-outline-variant/20 max-w-container-max mx-auto text-center">
    <p class="font-inter text-sm text-on-surface-variant/40">
      {footer.copyright}
    </p>
  </div>
</footer>
