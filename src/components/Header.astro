---
import { nav } from '../data/site.json';
---

<header class="fixed top-0 left-0 right-0 z-50 h-20 bg-background/90 backdrop-blur-md border-b border-outline-variant/30">
  <div class="h-full px-container-padding-desktop max-w-container-max mx-auto flex items-center justify-between">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-2">
      <span class="font-manrope text-label-md text-primary uppercase tracking-widest font-semibold">
        Dr. Dhiego Ventura
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {nav.links.map((item) => (
        <a
          href={item.href}
          class="font-manrope text-label-md text-on-surface-variant uppercase tracking-wider hover:text-primary hover:-translate-y-px transition-all duration-150"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile menu button -->
    <button class="md:hidden text-on-surface-variant hover:text-primary transition-colors">
      <span class="material-symbols-outlined text-2xl">menu</span>
    </button>
  </div>
</header>
