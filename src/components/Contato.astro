---
import Button from './ui/Button.astro';
import { contato, contact } from '../data/site.json';
---

<section id="contato" class="py-section-gap bg-surface-container-lowest relative">
  <div class="container-main relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 lg:gap-32 items-stretch">
      <div class="flex flex-col h-full">
        <h2 class="font-manrope text-headline-lg text-foreground mb-8 leading-tight">
          {contato.title}
        </h2>
        <p class="font-manrope text-body-lg text-on-surface-variant/80 mb-8 max-w-md">
          {contato.description}
        </p>
        <div class="space-y-6 flex-1 flex flex-col">
          <div class="flex items-center gap-6 p-6 rounded-lg bg-surface-container-low border border-outline-variant/20">
            <span class="material-symbols-outlined text-secondary text-4xl">location_on</span>
            <div>
              <p class="font-manrope font-bold text-foreground">{contact.address.street}</p>
              <p class="font-manrope text-on-surface-variant/60">{contact.address.neighborhood}, {contact.address.city} - {contact.address.state}</p>
            </div>
          </div>
          <div class="flex-1 min-h-[400px] overflow-hidden rounded-lg shadow-xl border border-white/5 relative">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3675.8621470511307!2d-43.29571042434206!3d-22.881550236970305!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x997d97184594ed%3A0xa032dbfecae136af!2sNutricionista%20Dhiego%20Ventura%20-%20Clinica%20Nutricionista%20Rio%20de%20Janeiro!5e0!3m2!1spt-BR!2sbr!4v1779861416045!5m2!1spt-BR!2sbr" 
              class="absolute inset-0 w-full h-full grayscale-[0.2] contrast-[1.1] hover:grayscale-0 transition-all duration-500"
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
          <div class="text-center lg:text-left">
            <a href={contact.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-primary font-bold hover:underline">
              <span class="material-symbols-outlined">map</span> Ver no Google Maps
            </a>
          </div>
        </div>
      </div>

      <div class="glass-card p-10 lg:p-16 rounded-lg shadow-2xl flex flex-col justify-center">
        <h3 class="font-manrope text-headline-md text-foreground mb-10 text-center">{contato.form.title}</h3>
        <form action={contato.form.formSubmitUrl} method="POST" class="space-y-10 flex-1 flex flex-col justify-between">
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <div>
            <label class="block font-manrope text-label-md text-on-surface-variant/80 mb-3">Nome Completo</label>
            <input
              type="text"
              name="name"
              required
              placeholder="Seu nome"
              class="w-full rounded-full border border-outline-variant/30 bg-surface-container-high pl-6 pr-6 py-5 text-base text-foreground placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/30 outline-none transition-all"
            />
          </div>
          <div>
            <label class="block font-manrope text-label-md text-on-surface-variant/80 mb-3">E-mail</label>
            <input
              type="email"
              name="email"
              required
              placeholder="seu@email.com"
              class="w-full rounded-full border border-outline-variant/30 bg-surface-container-high pl-6 pr-6 py-5 text-base text-foreground placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/30 outline-none transition-all"
            />
          </div>
          <div>
            <label class="block font-manrope text-label-md text-on-surface-variant/80 mb-3">WhatsApp</label>
            <input
              type="tel"
              name="phone"
              placeholder="(21) 00000-0000"
              class="w-full rounded-full border border-outline-variant/30 bg-surface-container-high pl-6 pr-6 py-5 text-base text-foreground placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/30 outline-none transition-all"
            />
          </div>
          <Button size="lg" class="w-full justify-center uppercase tracking-widest font-manrope text-sm">
            {contato.form.submitLabel}
          </Button>
        </form>
      </div>
    </div>
  </div>
</section>
