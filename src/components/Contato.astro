---
import Button from './ui/Button.astro';
import { contato, contact } from '../data/site.json';
---

<section id="contato" class="py-section-gap bg-surface-container-lowest relative">
  <div class="px-container-padding-desktop max-w-container-max mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 lg:gap-32 items-center">
      <div>
        <h2 class="font-manrope text-headline-lg text-off-white mb-8 leading-tight">
          {contato.title}
        </h2>
        <p class="font-manrope text-body-lg text-on-surface-variant/80 mb-8 max-w-md">
          {contato.description}
        </p>
        <div class="flex items-center gap-6 p-6 border border-primary/20 rounded-lg bg-surface-container-low mb-8">
          <span class="material-symbols-outlined text-secondary text-4xl">location_on</span>
          <div>
            <p class="font-manrope font-bold text-off-white">{contact.address.street}</p>
            <p class="font-manrope text-on-surface-variant/60">{contact.address.neighborhood}, {contact.address.city} - {contact.address.state}</p>
          </div>
        </div>
      </div>

      <div class="glass-card p-10 lg:p-16 rounded-lg shadow-2xl border border-primary/20">
        <h3 class="font-manrope text-headline-md text-off-white mb-10 text-center">{contato.form.title}</h3>
        <form action={contato.form.formSubmitUrl} method="POST" class="space-y-10">
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <div>
            <label class="block font-manrope text-label-md text-on-surface-variant/80 mb-3">Nome Completo</label>
            <input
              type="text"
              name="name"
              required
              placeholder="Seu nome"
              class="w-full rounded-full border border-outline-variant/30 bg-surface-container-high pl-6 pr-6 py-5 text-base text-off-white placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-2 focus:ring-primary outline-none transition-all"
            />
          </div>
          <div>
            <label class="block font-manrope text-label-md text-on-surface-variant/80 mb-3">E-mail</label>
            <input
              type="email"
              name="email"
              required
              placeholder="seu@email.com"
              class="w-full rounded-full border border-outline-variant/30 bg-surface-container-high pl-6 pr-6 py-5 text-base text-off-white placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-2 focus:ring-primary outline-none transition-all"
            />
          </div>
          <div>
            <label class="block font-manrope text-label-md text-on-surface-variant/80 mb-3">WhatsApp</label>
            <input
              type="tel"
              name="phone"
              placeholder="(21) 00000-0000"
              class="w-full rounded-full border border-outline-variant/30 bg-surface-container-high pl-6 pr-6 py-5 text-base text-off-white placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-2 focus:ring-primary outline-none transition-all"
            />
          </div>
          <Button size="lg" class="w-full justify-center uppercase tracking-widest font-manrope text-sm">
            {contato.form.submitLabel}
          </Button>
        </form>
      </div>
    </div>
  </div>
</section>
