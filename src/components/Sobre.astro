---
import Card from './ui/Card.astro';
import { sobre, brand } from '../data/site.json';
---

<section id="sobre" class="py-section-gap container-main">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div class="relative">
      <div class="absolute -top-6 -left-6 w-32 h-32 border-t-2 border-l-2 border-primary/40"></div>
      <img src="/images/about-diego.jpg" alt={sobre.name} class="rounded-lg shadow-2xl w-full relative z-10" width="500" height="600" />
      <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b-2 border-r-2 border-primary/40"></div>
    </div>

    <div>
      <h2 class="font-manrope text-headline-lg text-on-surface mb-2">{sobre.name}</h2>
      <p class="font-manrope text-label-md text-primary uppercase tracking-widest mb-6">{sobre.title}</p>
      <div class="font-manrope text-body-lg text-on-surface-variant/80 space-y-4">
        <p>{sobre.paragraph1}</p>
        <p>{sobre.paragraph2}</p>
      </div>

      <Card class="!border-primary/30 flex items-center gap-4 glass-card p-6 rounded-lg mt-8">
        <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
          <span class="material-symbols-outlined text-primary">verified</span>
        </div>
        <div>
          <p class="font-bold text-primary">CRN {brand.crn}</p>
          <p class="text-sm text-on-surface-variant/60">Conselho Regional de Nutrição</p>
        </div>
      </Card>
    </div>
  </div>
</section>
