---
import Card from './ui/Card.astro';
import { sobre, brand } from '../data/site.json';
---

<section id="sobre" class="py-section-gap bg-surface-container-low overflow-hidden">
  <div class="px-container-padding-desktop max-w-container-max mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
    <div class="relative">
      <div class="absolute -top-6 -left-6 w-32 h-32 border-t-2 border-l-2 border-primary/40"></div>
      <img src="/images/about-diego.jpg" alt={sobre.name} class="rounded-lg shadow-2xl relative z-10 w-full aspect-[4/5] object-cover" />
      <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b-2 border-r-2 border-primary/40"></div>
    </div>
    <div>
      <h2 class="text-headline-lg text-off-white mb-6">{sobre.name}</h2>
      <h3 class="text-headline-md text-primary mb-6">{sobre.title}</h3>
      <p class="text-on-surface-variant/80 text-body-lg mb-6 leading-relaxed">{sobre.paragraph1}</p>
      <p class="text-on-surface-variant/80 text-body-lg mb-10 leading-relaxed">{sobre.paragraph2}</p>
      <Card class="!border-primary/30 flex items-center gap-4 glass-card p-6 rounded-lg">
        <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
          <span class="material-symbols-outlined text-primary">verified</span>
        </div>
        <div>
          <p class="font-bold text-primary">CRN {brand.crn}</p>
          <p class="text-sm text-on-surface-variant/60">Conselho Regional de Nutrição</p>
        </div>
      </Card>
    </div>
  </div>
</section>
